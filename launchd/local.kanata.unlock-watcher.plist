<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>local.kanata.unlock-watcher</string>
    <key>ProgramArguments</key>
    <array>
        <string>__HOME__/.config/kanata/kanata_unlock_watcher.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/local.kanata.unlock-watcher.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/local.kanata.unlock-watcher.log</string>
</dict>
</plist>
