{
    "title": "NuPhy Home Row Mods",
    "rules": [
        {
            "description": "NuPhy only: Home row mods (left hand: A S D F)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "a" },
                    "to": [{ "key_code": "left_command" }],
                    "to_if_alone": [{ "key_code": "a" }],
                    "parameters": {
                        "basic.to_if_held_down_threshold_milliseconds": 150,
                        "basic.to_if_alone_timeout_milliseconds": 150
                    },
                    "conditions": [
                        {
                            "type": "device_if",
                            "identifiers": [
                                { "vendor_id": 6645, "product_id": 4136 },
                                { "vendor_id": 2007 }
                            ]
                        }
                    ]
                },
