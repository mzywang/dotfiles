{
    "title": "NuPhy Home Row Mods",
    "rules": [
        {
            "description": "NuPhy only: Home row mods (left hand: A R S T, Colemak firmware layout)",
            "manipulators": [
                {
                    "type": "basic",
                    "from": { "key_code": "a" },
                    "to": [{ "key_code": "left_command" }],
                    "to_if_alone": [{ "key_code": "a" }],
                    "parameters": {
                        "basic.to_if_held_down_threshold_milliseconds": 220,
                        "basic.to_if_alone_timeout_milliseconds": 220
                    },
                    "conditions": [
                        {
                            "type": "device_if",
                            "identifiers": [
                                { "vendor_id": 6645, "product_id": 4136 },
                                { "vendor_id": 2007 }
                            ]
                        }
                    ]
